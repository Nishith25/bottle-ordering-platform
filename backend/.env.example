PORT=5001
NODE_ENV=development

MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@YOUR_CLUSTER.mongodb.net/bottle_ordering?retryWrites=true&w=majority
MONGODB_DB=bottle_ordering

JWT_SECRET=REPLACE_WITH_A_LONG_RANDOM_SECRET
JWT_EXPIRES_IN=7d

CLIENT_ORIGINS=http://localhost:8082,http://localhost:19006,http://localhost:5174

# Use the same reachable address used by the customer app.
# For phone testing, replace localhost with your Mac's local IP.
BACKEND_PUBLIC_URL=http://localhost:5001

RAZORPAY_KEY_ID=rzp_test_REPLACE_ME
RAZORPAY_KEY_SECRET=REPLACE_ME
RAZORPAY_WEBHOOK_SECRET=REPLACE_ME

RAZORPAY_BUSINESS_NAME=Fresh Bottle Store
RAZORPAY_CHECKOUT_TIMEOUT_SECONDS=900
PAYMENT_SESSION_EXPIRY_MINUTES=20